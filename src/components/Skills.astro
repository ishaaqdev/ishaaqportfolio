---
const skillGroups = [
  {
    title: "AI & ML",
    skills: [
      { icon: "psychology", label: "TensorFlow / PyTorch" },
      { icon: "neurology", label: "Deep Learning" },
      { icon: "visibility", label: "Computer Vision" },
      { icon: "memory", label: "Edge AI" },
      { icon: "terminal", label: "Python" },
    ],
  },
  {
    title: "Backend",
    skills: [
      { icon: "database", label: "Node.js / Express" },
      { icon: "storage", label: "MongoDB" },
      { icon: "api", label: "RESTful APIs" },
      { icon: "key", label: "JWT / Auth" },
    ],
  },
  {
    title: "Frontend",
    skills: [
      { icon: "pentagon", label: "React" },
      { icon: "frame_inspect", label: "Next.js" },
      { icon: "code", label: "TypeScript" },
      { icon: "devices", label: "Responsive UI" },
    ],
  },
  {
    title: "Hardware",
    skills: [
      { icon: "memory", label: "Raspberry Pi" },
      { icon: "settings_input_component", label: "Arduino" },
      { icon: "precision_manufacturing", label: "Embedded Systems" },
      { icon: "sensors", label: "IoT Integration" },
    ],
  },
];
---

<section id="skills" class="w-full border-t border-outline-variant bg-surface">
  <div class="max-w-[1200px] mx-auto px-margin-mobile md:px-margin-desktop py-stack-lg md:py-[120px]">
    <div class="mb-12">
      <h2 class="font-headline-lg text-headline-lg text-primary mb-6 uppercase tracking-tight">Technical Skills</h2>
      <div class="w-16 h-2 bg-primary"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {skillGroups.map((group) => (
        <div class="card-brutalist p-8">
          <h3 class="font-headline-md text-headline-md text-primary mb-6 border-b-2 border-primary pb-2 inline-block">
            {group.title}
          </h3>
          <ul class="space-y-4 font-body-md text-body-md text-on-surface-variant">
            {group.skills.map(({ icon, label }) => (
              <li class="flex items-center gap-3">
                <span class="material-symbols-outlined text-primary">{icon}</span>
                {label}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
