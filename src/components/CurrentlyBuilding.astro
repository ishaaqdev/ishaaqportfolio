---
const items = [
  {
    title: "Recylo",
    description: "AI-powered waste sorting platform with CNN classification on Raspberry Pi 5.",
    github: "https://github.com/ishaaqdev/Recylo-SIH/",
    live: "https://ishaaqdev.github.io/Recylo-SIH/",
  },
  {
    title: "Reverse Vending Machine",
    description: "Next iteration of the patented RVM — improved conveyor mechanics and reward system.",
    github: "https://github.com/ishaaqdev/IWM-Reverse-Vending-Machine",
    live: "https://ishaaqdev.github.io/IWM-Reverse-Vending-Machine/",
  },
  {
    title: "SEL v2 — Edge AI Research",
    description: "Improved curriculum scheduling for Staged Embarrassment Learning across broader model architectures.",
    github: "https://github.com/ishaaqdev/Staged-Embarrassment-Learning",
    live: "https://ishaaqdev.github.io/Staged-Embarrassment-Learning/",
  },
];
---

<section id="building" class="w-full border-t border-outline-variant bg-surface-container-lowest">
  <div class="max-w-[1200px] mx-auto px-margin-mobile md:px-margin-desktop py-stack-lg md:py-[120px]">
    <div class="mb-12">
      <h2 class="font-headline-lg text-headline-lg text-primary mb-2 uppercase tracking-tight">What I'm Building Now</h2>
      <p class="font-body-md text-body-md text-secondary mt-3">Active projects — shipping in 2025–26.</p>
      <div class="w-16 h-2 bg-primary mt-6"></div>
    </div>

    <div class="flex flex-col gap-0 divide-y divide-outline-variant border-t border-outline-variant">
      {items.map((item, i) => (
        <div class="flex flex-col md:flex-row md:items-center justify-between py-8 gap-4">
          <div class="flex items-start gap-6">
            <span class="font-[Poppins] text-secondary text-label-sm mt-1 w-6 flex-shrink-0 tabular-nums">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div>
              <div class="flex items-center gap-3 mb-1">
                <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
                <h3 class="font-headline-md text-headline-md text-primary">{item.title}</h3>
              </div>
              <p class="font-body-md text-body-md text-on-surface-variant">{item.description}</p>
            </div>
          </div>
          <div class="flex gap-3 md:flex-shrink-0 pl-12 md:pl-0">
            <a
              href={item.github}
              target="_blank"
              rel="noopener"
              aria-label="GitHub"
              class="inline-flex items-center gap-2 border border-outline-variant px-4 py-2 font-label-sm text-label-sm uppercase text-secondary hover:border-primary hover:text-primary transition-colors"
            >
              <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.041-1.416-4.041-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              <span class="hidden sm:inline">GitHub</span>
            </a>
            <a
              href={item.live}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 border border-outline-variant px-4 py-2 font-label-sm text-label-sm uppercase text-secondary hover:border-primary hover:text-primary transition-colors"
            >
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <line x1="2" y1="12" x2="22" y2="12"/>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
              </svg>
              <span class="hidden sm:inline">Live</span>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
