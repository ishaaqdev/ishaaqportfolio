---
const items = [
  {
    label: "Learning",
    text: "Generative AI — working through DeepLearning.AI courses on LLMs, prompt engineering, and RAG systems.",
  },
  {
    label: "Exploring",
    text: "Agentic AI — how autonomous agents reason, plan, and use tools. Planning to build projects in this space soon.",
  },
  {
    label: "Next Up",
    text: "Figuring out what to build next at the intersection of AI agents and real-world utility.",
  },
];
---

<section id="building" class="w-full border-t border-outline-variant bg-surface-container-lowest">
  <div class="max-w-[1200px] mx-auto px-margin-mobile md:px-margin-desktop py-stack-lg md:py-[120px]">
    <div class="mb-12">
      <h2 class="font-headline-lg text-headline-lg text-primary mb-2 uppercase tracking-tight">What I'm Doing Now</h2>
      <p class="font-body-md text-body-md text-secondary mt-3">Current focus — June 2026.</p>
      <div class="w-16 h-2 bg-primary mt-6"></div>
    </div>

    <div class="flex flex-col divide-y divide-outline-variant border-t border-outline-variant">
      {items.map((item) => (
        <div class="flex flex-col md:flex-row gap-4 md:gap-12 py-8">
          <div class="flex items-center gap-3 md:w-40 flex-shrink-0">
            <span class="w-2 h-2 bg-primary rounded-full animate-pulse flex-shrink-0"></span>
            <span class="font-[Poppins] text-xs uppercase tracking-widest text-secondary">{item.label}</span>
          </div>
          <p class="font-body-lg text-body-lg text-on-surface-variant">{item.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
