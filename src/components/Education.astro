---
const education = [
  {
    degree: "BE in Information Science & Engineering",
    institution: "BGS College of Engineering & Technology",
    score: "8.06 GPA",
    year: "2023 – 2027",
  },
  {
    degree: "2nd PUC (PCMC)",
    institution: "Falcon PU College",
    score: "84%",
    year: "2021 – 2023",
  },
  {
    degree: "SSLC — Class 10",
    institution: "St. Joseph's Indian High School",
    score: "74%",
    year: "2021",
  },
];
---

<section id="education" class="w-full border-t border-outline-variant bg-surface">
  <div class="max-w-[1200px] mx-auto px-margin-mobile md:px-margin-desktop py-stack-lg md:py-[120px]">
    <div class="mb-12">
      <h2 class="font-headline-lg text-headline-lg text-primary mb-6 uppercase tracking-tight">Education</h2>
      <div class="w-16 h-2 bg-primary"></div>
    </div>

    <div class="space-y-0">
      {education.map((item, i) => (
        <div class={`flex flex-col md:flex-row md:items-center justify-between py-8 ${i < education.length - 1 ? 'border-b border-outline-variant' : ''}`}>
          <div class="flex flex-col gap-1">
            <p class="font-label-sm text-label-sm text-secondary uppercase tracking-widest">{item.year}</p>
            <h3 class="font-headline-md text-headline-md text-primary">{item.degree}</h3>
            <p class="font-body-md text-body-md text-on-surface-variant">{item.institution}</p>
          </div>
          <div class="mt-4 md:mt-0 flex-shrink-0">
            <span class="inline-block border border-outline-variant px-3 py-1 font-[Poppins] text-secondary text-body-md">
              {item.score}
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
