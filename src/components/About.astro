---
---

<section id="about" class="w-full border-t border-outline-variant bg-surface-container-lowest">
  <div class="max-w-[1200px] mx-auto px-margin-mobile md:px-margin-desktop py-stack-lg md:py-[120px]">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-start">

      <!-- Quote column -->
      <div class="md:col-span-5">
        <h2 class="font-headline-lg text-headline-lg text-primary mb-6 uppercase tracking-tight">About Me</h2>
        <div class="w-16 h-2 bg-primary mb-10"></div>

        <!-- Pull quote block -->
        <div class="relative">
          <div class="absolute -left-4 top-0 bottom-0 w-1 bg-primary"></div>
          <div class="pl-8">
            <svg class="w-8 h-8 text-primary/20 mb-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
            </svg>
            <blockquote class="font-[Poppins] text-[1.25rem] leading-relaxed text-primary font-semibold italic">
              "To see the boundaries of the possible, we must attempt the impossible."
            </blockquote>
            <cite class="block mt-4 font-label-sm text-label-sm text-secondary uppercase tracking-widest not-italic">
              — Mehmed II
            </cite>
          </div>
        </div>
      </div>

      <!-- Bio column -->
      <div class="md:col-span-7 space-y-6">
        <p class="font-body-lg text-body-lg text-on-surface-variant">
          Information Science student focused on <strong class="text-primary">AI, Edge Computing, and Sustainability.</strong>
        </p>
        <p class="font-body-lg text-body-lg text-on-surface-variant">
          Built patented waste-management systems, published ML research on edge-efficient training, and shipped full-stack products used in national competitions.
        </p>
        <p class="font-body-lg text-body-lg text-on-surface-variant">
          Currently seeking internship opportunities in <strong class="text-primary">Software Engineering</strong> and <strong class="text-primary">AI Research.</strong>
        </p>

        <div class="grid grid-cols-2 gap-4 pt-4">
          <div class="p-4 border border-outline-variant">
            <p class="font-label-sm text-label-sm text-secondary uppercase">Education</p>
            <p class="font-body-md text-body-md text-primary font-bold">BGS College of Engineering</p>
          </div>
          <div class="p-4 border border-outline-variant">
            <p class="font-label-sm text-label-sm text-secondary uppercase">Focus</p>
            <p class="font-body-md text-body-md text-primary font-bold">AI &amp; Edge Systems</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
