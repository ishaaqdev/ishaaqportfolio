---
interface Props {
  currentPage?: string;
}
const { currentPage = 'home' } = Astro.props;
---

<nav class="w-full top-0 sticky border-b border-outline-variant bg-surface z-50 transition-all duration-300">
  <div class="flex justify-between items-center max-w-[1200px] mx-auto px-margin-mobile md:px-margin-desktop h-20">
    <div class="flex items-center gap-6">
      <a href="/" class="font-headline-md text-headline-md font-bold text-primary tracking-tight">Ishaaq</a>
      <div class="hidden lg:flex items-center gap-4 text-primary border-l border-outline-variant pl-6">
        <a href="https://www.linkedin.com/in/ishaaq42/" target="_blank" rel="noopener" title="LinkedIn" class="hover:text-secondary transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
        </a>
        <a href="https://github.com/ishaaqdev" target="_blank" rel="noopener" title="GitHub" class="hover:text-secondary transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.041-1.416-4.041-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
        <a href="mailto:ishaaq.tech@gmail.com" title="Email" class="hover:text-secondary transition-colors">
          <span class="material-symbols-outlined text-xl">mail</span>
        </a>
      </div>
    </div>

    <ul class="hidden md:flex items-center gap-8 font-['Poppins'] text-label-md uppercase tracking-widest">
      {[
        { href: '/#home',         label: 'Home',         id: 'home' },
        { href: '/#about',        label: 'About',        id: 'about' },
        { href: '/#projects',     label: 'Projects',     id: 'projects' },
        { href: '/#achievements', label: 'Achievements', id: 'achievements' },
        { href: '/#education',    label: 'Education',    id: 'education' },
        { href: '/#contact',      label: 'Contact',      id: 'contact' },
      ].map(({ href, label, id }) => (
        <li>
          <a href={href} class={`transition-colors ${currentPage === id ? 'text-primary' : 'text-secondary hover:text-primary'}`}>
            {label}
          </a>
        </li>
      ))}
    </ul>

    <div class="hidden md:flex items-center gap-3">
      <!-- Dark mode toggle: half-black / half-white circle -->
      <button
        id="theme-toggle"
        aria-label="Toggle dark mode"
        title="Toggle dark / light mode"
        class="w-7 h-7 rounded-full border-2 border-primary overflow-hidden flex-shrink-0 hover:scale-110 transition-transform"
      >
        <span class="w-full h-full flex">
          <span class="w-1/2 h-full bg-black dark-left"></span>
          <span class="w-1/2 h-full bg-white dark-right border-l border-outline-variant"></span>
        </span>
      </button>
      <a href="/resume.pdf" download class="inline-flex items-center justify-center px-6 py-3 btn-brutalist font-[Poppins] text-label-md bg-primary text-on-primary hover:bg-surface hover:text-primary">
        Download Resume
      </a>
    </div>

    <button aria-label="Toggle Menu" class="md:hidden text-primary" id="mobile-toggle">
      <span class="material-symbols-outlined text-2xl">menu</span>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden bg-surface border-b border-outline-variant px-margin-mobile py-6 space-y-4">
    <a href="/#home"         class="block font-label-md text-label-md uppercase tracking-widest text-primary font-bold">Home</a>
    <a href="/#about"        class="block font-label-md text-label-md uppercase tracking-widest text-secondary">About</a>
    <a href="/#projects"     class="block font-label-md text-label-md uppercase tracking-widest text-secondary">Projects</a>
    <a href="/#achievements" class="block font-label-md text-label-md uppercase tracking-widest text-secondary">Achievements</a>
    <a href="/#education"    class="block font-label-md text-label-md uppercase tracking-widest text-secondary">Education</a>
    <a href="/#contact"      class="block font-label-md text-label-md uppercase tracking-widest text-secondary">Contact</a>
    <a href="/resume.pdf" download class="block font-label-md text-label-md uppercase tracking-widest text-secondary">Resume</a>
  </div>
</nav>

<script>
  document.getElementById('mobile-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });

  function applyThemeToIcon(isDark) {
    const left  = document.querySelector('.dark-left')  as HTMLElement | null;
    const right = document.querySelector('.dark-right') as HTMLElement | null;
    if (!left || !right) return;
    // In dark mode: invert the halves so it looks different
    left.style.backgroundColor  = isDark ? '#ffffff' : '#000000';
    right.style.backgroundColor = isDark ? '#000000' : '#ffffff';
  }

  // Apply icon state on load
  applyThemeToIcon(document.documentElement.classList.contains('dark'));

  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const html   = document.documentElement;
    const isDark = html.classList.contains('dark');
    html.classList.toggle('dark',  !isDark);
    html.classList.toggle('light',  isDark);
    localStorage.setItem('theme', isDark ? 'light' : 'dark');
    applyThemeToIcon(!isDark);
  });
</script>
