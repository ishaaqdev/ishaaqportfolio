---
---

<section
  id="home"
  class="w-full max-w-[1200px] mx-auto px-margin-mobile md:px-margin-desktop py-stack-lg md:py-[120px] flex flex-col md:flex-row items-center md:items-start justify-between gap-stack-md"
>
  <!-- Text -->
  <div class="flex-1 flex flex-col items-start w-full order-2 md:order-1">
    <span class="inline-block px-3 py-1 border border-primary text-label-sm font-label-sm uppercase mb-6 bg-surface-container-low">
      Portfolio 2026
    </span>
    <h1 class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-primary mb-4 leading-tight">
      Mohammed<br />Ishaaq.
    </h1>
    <h2 class="font-headline-md text-headline-md text-secondary mb-8 max-w-xl border-l-4 border-primary pl-4">
      Engineer building AI systems for real-world impact.
    </h2>
    <p class="font-body-lg text-body-lg text-on-surface-variant mb-10 max-w-lg">
      Patented waste-management hardware. Edge AI research. Full-stack products.
      Looking for an internship where I can ship things that matter.
    </p>
    <div class="flex flex-wrap gap-4">
      <a
        href="#projects"
        class="inline-flex items-center justify-center px-8 py-4 btn-brutalist bg-primary text-on-primary font-label-md text-label-md hover:bg-surface hover:text-primary"
      >
        View My Work
      </a>
      <a
        href="#about"
        class="inline-flex items-center justify-center px-8 py-4 btn-brutalist bg-surface text-primary font-label-md text-label-md hover:bg-primary hover:text-on-primary"
      >
        Read More
      </a>
    </div>

    <!-- Stats row -->
    <div class="mt-stack-lg pt-8 border-t border-outline-variant w-full flex gap-12">
      <div>
        <p class="font-display-lg text-headline-lg text-primary uppercase">7th Sem</p>
        <p class="font-label-sm text-label-sm text-secondary uppercase mt-1">Student</p>
      </div>
      <div>
        <p class="font-display-lg text-headline-lg text-primary">20+</p>
        <p class="font-label-sm text-label-sm text-secondary uppercase mt-1">Projects Done</p>
      </div>
    </div>
  </div>

  <!-- Photo -->
  <div class="flex justify-center md:justify-center w-full md:w-auto order-1 md:order-2 md:pt-8">
    <div class="relative w-52 h-52 md:w-64 md:h-64 border-2 border-primary p-3 bg-surface-container-low flex-shrink-0">
      <div class="w-full h-full border border-primary overflow-hidden">
        <img
          src="/profile.png"
          alt="Mohammed Ishaaq"
          class="w-full h-full object-cover grayscale contrast-125"
          loading="eager"
        />
      </div>
      <div class="absolute -bottom-4 -right-4 w-full h-full border-2 border-primary -z-10 bg-primary"></div>
    </div>
  </div>
</section>
