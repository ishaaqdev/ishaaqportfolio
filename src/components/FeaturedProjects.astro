---
import { featuredProjects } from '../data/projects.js';
---

<section id="projects" class="w-full border-t border-outline-variant bg-surface-container-lowest">
  <div class="max-w-[1200px] mx-auto px-margin-mobile md:px-margin-desktop py-stack-lg md:py-[120px]">
    <div class="mb-12">
      <h2 class="font-headline-lg text-headline-lg text-primary mb-6 uppercase tracking-tight">Selected Work</h2>
      <div class="w-16 h-2 bg-primary"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {featuredProjects.map((project, i) => (
        <div
          class="project-card opacity-0 translate-y-8 transition-all duration-700 card-brutalist p-8 flex flex-col h-full"
          style={`transition-delay: ${i * 100}ms`}
        >
          <div class="mb-4">
            <span class="inline-block px-2 py-1 border border-primary text-label-sm font-label-sm uppercase bg-surface-container-low mb-3">
              {project.category}
            </span>
            <h3 class="font-headline-md text-headline-md text-primary mb-2">{project.title}</h3>
          </div>
          <p
            class="font-body-md text-body-md text-on-surface-variant mb-6 flex-grow leading-relaxed"
            set:html={project.description}
          />
          <div class="flex gap-6 pt-2 border-t border-outline-variant">
            <a
              href={project.github}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 font-[Poppins] text-label-md text-primary hover:underline uppercase tracking-wide group"
            >
              <!-- GitHub icon -->
              <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.041-1.416-4.041-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              GitHub
            </a>
            <a
              href={project.live}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 font-[Poppins] text-label-md text-primary hover:underline uppercase tracking-wide group"
            >
              <!-- Globe icon -->
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <line x1="2" y1="12" x2="22" y2="12"/>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
              </svg>
              {project.liveLabel}
            </a>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 flex justify-center">
      <a
        href="/projects"
        class="inline-flex items-center justify-center px-8 py-4 btn-brutalist bg-primary text-on-primary font-label-md text-label-md hover:bg-surface hover:text-primary"
      >
        See All Projects
      </a>
    </div>
  </div>
</section>

<script>
  const cards = document.querySelectorAll('.project-card');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.remove('opacity-0', 'translate-y-8');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );
  cards.forEach((card) => observer.observe(card));
</script>
